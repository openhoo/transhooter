{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "images",
    "existingSecret",
    "migratorSecret",
    "magicLinkSealKeys",
    "providerSecretName",
    "spool",
    "config",
    "rollout",
    "telemetry",
    "ingress"
  ],
  "oneOf": [
    {
      "required": ["config", "providerSecretKeys"],
      "properties": {
        "config": {
          "type": "object",
          "required": ["providerProfile", "providers"],
          "properties": {
            "providerProfile": { "const": "google-eu" },
            "providers": {
              "type": "object",
              "required": ["googleEu"]
            }
          }
        },
        "providerSecretKeys": {
          "type": "array",
          "items": { "const": "google-adc.json" },
          "minItems": 1,
          "maxItems": 1
        }
      }
    },
    {
      "required": ["config", "providerSecretKeys"],
      "properties": {
        "config": {
          "type": "object",
          "required": ["providerProfile", "providers"],
          "properties": {
            "providerProfile": { "const": "google-speech-eu" },
            "providers": {
              "type": "object",
              "required": ["googleSpeechEu"]
            }
          }
        },
        "providerSecretKeys": {
          "type": "array",
          "items": { "const": "google-adc.json" },
          "minItems": 1,
          "maxItems": 1
        }
      }
    },
    {
      "required": ["config", "providerSecretKeys"],
      "properties": {
        "config": {
          "type": "object",
          "required": ["providerProfile", "providers"],
          "properties": {
            "providerProfile": { "const": "deepgram-deepl-eu" },
            "providers": {
              "type": "object",
              "required": ["deepgramDeeplEu"]
            }
          }
        },
        "providerSecretKeys": {
          "type": "array",
          "items": { "enum": ["deepgram-api-key", "deepl-api-key"] },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        }
      }
    }
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "ingress": {
            "properties": {
              "trustedClientIp": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              }
            },
            "required": ["trustedClientIp"]
          }
        },
        "required": ["ingress"]
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "trustedClientIpHeader": {
                "type": "string",
                "pattern": "^x-[a-z0-9-]+$",
                "not": { "enum": ["x-forwarded-for", "x-real-ip"] }
              }
            },
            "required": ["trustedClientIpHeader"]
          }
        }
      },
      "else": {
        "properties": {
          "config": {
            "properties": { "trustedClientIpHeader": { "const": "" } }
          }
        }
      }
    }
  ],
  "properties": {
    "existingSecret": { "type": "string", "minLength": 1 },
    "migratorSecret": {
      "type": "object",
      "additionalProperties": false,
      "required": ["existingSecret", "secretKey"],
      "properties": {
        "existingSecret": {
          "type": "string",
          "minLength": 1
        },
        "secretKey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        }
      }
    },
    "magicLinkSealKeys": {
      "type": "object",
      "additionalProperties": false,
      "required": ["existingSecret", "secretKey", "mountPath"],
      "properties": {
        "existingSecret": {
          "type": "string",
          "minLength": 1
        },
        "secretKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "mountPath": {
          "type": "string",
          "pattern": "^/run/secrets/[A-Za-z0-9._-]+$"
        }
      }
    },
    "providerSecretName": { "type": "string", "minLength": 1 },
    "providerSecretKeys": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "egressConfigSecret": { "type": "string", "minLength": 1 },
    "rollout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtimeSecretRevision", "providerSecretRevision", "egressConfigSecretRevision"],
      "properties": {
        "runtimeSecretRevision": { "type": "string", "pattern": ".*\\S.*" },
        "providerSecretRevision": { "type": "string", "pattern": ".*\\S.*" },
        "egressConfigSecretRevision": { "type": "string", "pattern": ".*\\S.*" }
      }
    },
    "images": {
      "propertyNames": {
        "enum": ["web", "controlWorker", "translationWorker", "spoolDrainer", "egress"]
      },
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["repository", "tag", "pullPolicy"],
        "properties": {
          "repository": { "type": "string", "minLength": 1 },
          "tag": { "type": "string", "minLength": 1, "not": { "const": "latest" } },
          "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
        }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "endpoint",
        "traceSampleRatio",
        "metricExportIntervalMillis",
        "collector"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": {
          "type": "string",
          "anyOf": [{ "const": "" }, { "pattern": "^https?://[^/\\s]+(?::[0-9]+)?(?:/.*)?$" }]
        },
        "traceSampleRatio": { "type": "number", "minimum": 0, "maximum": 1 },
        "metricExportIntervalMillis": { "type": "integer", "minimum": 1000 },
        "collector": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "image", "replicas", "ports", "resources"],
          "properties": {
            "enabled": { "type": "boolean" },
            "image": {
              "type": "object",
              "additionalProperties": false,
              "required": ["repository", "tag", "pullPolicy"],
              "properties": {
                "repository": { "const": "otel/opentelemetry-collector-contrib" },
                "tag": { "type": "string", "minLength": 1, "not": { "const": "latest" } },
                "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
              }
            },
            "replicas": { "type": "integer", "minimum": 1 },
            "ports": {
              "type": "object",
              "additionalProperties": false,
              "required": ["otlpGrpc", "otlpHttp", "prometheus", "health"],
              "properties": {
                "otlpGrpc": { "const": 4317 },
                "otlpHttp": { "const": 4318 },
                "prometheus": { "const": 8889 },
                "health": { "const": 13133 }
              }
            },
            "resources": {
              "type": "object",
              "additionalProperties": false,
              "required": ["requests", "limits"],
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["cpu", "memory"],
                  "properties": {
                    "cpu": { "type": "string", "minLength": 1 },
                    "memory": { "type": "string", "minLength": 1 }
                  }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["cpu", "memory"],
                  "properties": {
                    "cpu": { "type": "string", "minLength": 1 },
                    "memory": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "replicas": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 1 } },
    "spool": {
      "type": "object",
      "required": ["existingClaim"],
      "properties": { "existingClaim": { "type": "string", "minLength": 1 } }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appEnv",
        "providerProfile",
        "livekitUrl",
        "s3Endpoint",
        "s3PublicEndpoint",
        "s3Region",
        "s3Bucket",
        "s3KmsKeyId",
        "archiveRequireKms",
        "publicUrl",
        "publicLivekitUrl",
        "trustedClientIpHeader",
        "internalIssuer",
        "internalAudience",
        "kubernetesApiAudience",
        "providers"
      ],
      "properties": {
        "appEnv": { "const": "production" },
        "providerProfile": { "enum": ["google-eu", "google-speech-eu", "deepgram-deepl-eu"] },
        "archiveRequireKms": { "const": true },
        "livekitUrl": { "type": "string", "pattern": "^wss://" },
        "publicUrl": { "type": "string", "pattern": "^https://" },
        "publicLivekitUrl": { "type": "string", "pattern": "^wss://" },
        "trustedClientIpHeader": {
          "type": "string",
          "anyOf": [
            { "const": "" },
            {
              "pattern": "^x-[a-z0-9-]+$",
              "not": { "enum": ["x-forwarded-for", "x-real-ip"] }
            }
          ]
        },
        "s3Endpoint": { "type": "string", "pattern": "^https://" },
        "s3PublicEndpoint": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://[^/\\s]+(?::[0-9]+)?(?:/.*)?$"
        },
        "s3KmsKeyId": { "type": "string", "pattern": ".*\\S.*" },
        "s3Region": { "type": "string", "minLength": 1 },
        "s3Bucket": { "type": "string", "minLength": 1 },
        "kubernetesApiAudience": { "type": "string", "pattern": "^https://" },
        "internalIssuer": { "type": "string", "pattern": "^https://" },
        "internalAudience": { "type": "string", "minLength": 1 },
        "bootstrapAdminName": { "type": "string", "minLength": 1 },
        "providers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "googleEu": {
              "type": "object",
              "required": [
                "cloudProject",
                "quotaProject",
                "speechEndpoint",
                "speechRecognizer",
                "speechModel",
                "translationEndpoint",
                "translationParent",
                "translationModel",
                "ttsEndpoint",
                "ttsModel",
                "ttsVoice",
                "sttStreams",
                "sttMessagesMinute",
                "translationRequestsMinute",
                "translationCharactersMinute",
                "ttsSessions",
                "ttsStartsMinute"
              ],
              "additionalProperties": false,
              "properties": {
                "cloudProject": { "type": "string", "minLength": 1 },
                "quotaProject": { "type": "string", "minLength": 1 },
                "speechEndpoint": { "const": "eu-speech.googleapis.com" },
                "speechRecognizer": {
                  "type": "string",
                  "pattern": "^projects/[^/]+/locations/eu/recognizers/_$"
                },
                "speechModel": { "type": "string", "minLength": 1 },
                "translationEndpoint": { "const": "translate-eu.googleapis.com" },
                "translationParent": {
                  "type": "string",
                  "pattern": "^projects/[^/]+/locations/eu$"
                },
                "translationModel": {
                  "type": "string",
                  "pattern": "^projects/[^/]+/locations/eu/models/general/nmt$"
                },
                "ttsEndpoint": { "const": "eu-texttospeech.googleapis.com" },
                "ttsModel": { "type": "string", "minLength": 1 },
                "ttsVoice": { "type": "string", "minLength": 1 },
                "sttStreams": { "type": "integer", "minimum": 1 },
                "sttMessagesMinute": { "type": "integer", "minimum": 1 },
                "translationRequestsMinute": { "type": "integer", "minimum": 1 },
                "translationCharactersMinute": { "type": "integer", "minimum": 1 },
                "ttsSessions": { "type": "integer", "minimum": 1 },
                "ttsStartsMinute": { "type": "integer", "minimum": 1 }
              }
            },
            "googleSpeechEu": {
              "type": "object",
              "required": [
                "cloudProject",
                "quotaProject",
                "speechLocation",
                "speechModel",
                "translationLocation",
                "translationModel",
                "ttsLocation",
                "ttsVoice",
                "ttsVoiceLocale"
              ],
              "additionalProperties": false,
              "properties": {
                "cloudProject": { "type": "string", "minLength": 1 },
                "quotaProject": { "type": "string", "minLength": 1 },
                "speechLocation": { "const": "europe-west3" },
                "speechModel": { "const": "long" },
                "translationLocation": { "const": "europe-west1" },
                "translationModel": { "const": "general/base" },
                "ttsLocation": { "const": "eu" },
                "ttsVoice": { "type": "string", "minLength": 1 },
                "ttsVoiceLocale": { "type": "string", "minLength": 1 }
              }
            },
            "deepgramDeeplEu": {
              "type": "object",
              "required": [
                "deepgramListenEndpoint",
                "deepgramSpeakEndpoint",
                "deepgramSttModel",
                "deepgramTtsModel",
                "deepgramVoice",
                "deepgramApprovedVoices",
                "deeplEndpoint",
                "deeplModelType",
                "deepgramStreams",
                "deepgramAudioSecondsMinute",
                "deeplRequestsMinute",
                "deeplCharactersMinute"
              ],
              "additionalProperties": false,
              "properties": {
                "deepgramListenEndpoint": { "const": "wss://api.eu.deepgram.com/v1/listen" },
                "deepgramSpeakEndpoint": { "const": "wss://api.eu.deepgram.com/v1/speak" },
                "deepgramSttModel": { "const": "nova-3" },
                "deepgramTtsModel": { "const": "aura-2" },
                "deepgramVoice": { "type": "string", "minLength": 1 },
                "deepgramApprovedVoices": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "minItems": 1,
                  "uniqueItems": true
                },
                "deeplEndpoint": { "const": "https://api.deepl.com" },
                "deeplModelType": { "enum": ["latency_optimized", "quality_optimized"] },
                "deepgramStreams": { "type": "integer", "minimum": 1 },
                "deepgramAudioSecondsMinute": { "type": "integer", "minimum": 1 },
                "deeplRequestsMinute": { "type": "integer", "minimum": 1 },
                "deeplCharactersMinute": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "className", "annotations", "trustedClientIp", "hosts", "tls"],
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": {
          "type": "object",
          "propertyNames": {
            "not": { "const": "nginx.ingress.kubernetes.io/configuration-snippet" }
          },
          "additionalProperties": { "type": "string" }
        },
        "trustedClientIp": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "controller",
            "configurationSnippetEnabled",
            "namespaceSelector",
            "podSelector"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "controller": { "const": "nginx" },
            "configurationSnippetEnabled": { "type": "boolean" },
            "namespaceSelector": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "matchLabels": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": { "type": "string" }
                },
                "matchExpressions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["key", "operator"],
                    "properties": {
                      "key": { "type": "string", "minLength": 1 },
                      "operator": { "enum": ["In", "NotIn", "Exists", "DoesNotExist"] },
                      "values": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                      }
                    }
                  }
                }
              }
            },
            "podSelector": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "matchLabels": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": { "type": "string" }
                },
                "matchExpressions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["key", "operator"],
                    "properties": {
                      "key": { "type": "string", "minLength": 1 },
                      "operator": { "enum": ["In", "NotIn", "Exists", "DoesNotExist"] },
                      "values": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                      }
                    }
                  }
                }
              }
            }
          },
          "allOf": [
            {
              "if": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              },
              "then": {
                "properties": {
                  "configurationSnippetEnabled": { "const": true },
                  "namespaceSelector": { "minProperties": 1 },
                  "podSelector": { "minProperties": 1 }
                }
              }
            }
          ]
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["host", "paths"],
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["path"],
                  "properties": {
                    "path": { "type": "string", "pattern": "^/" },
                    "pathType": { "enum": ["Exact", "Prefix", "ImplementationSpecific"] }
                  }
                }
              }
            }
          }
        },
        "tls": { "type": "array", "items": { "type": "object" } }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "trustedClientIp": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              }
            }
          },
          "then": {
            "properties": {
              "enabled": { "const": true },
              "className": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "egress": {
      "type": "object",
      "required": ["enabled", "replicas", "seccomp", "resources"],
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 1 },
        "seccomp": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "enum": ["RuntimeDefault", "Localhost"] },
            "localhostProfile": { "type": "string" }
          },
          "allOf": [
            {
              "if": { "properties": { "type": { "const": "Localhost" } } },
              "then": {
                "required": ["localhostProfile"],
                "properties": { "localhostProfile": { "type": "string", "minLength": 1 } }
              }
            }
          ]
        }
      }
    }
  }
}

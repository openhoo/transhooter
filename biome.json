{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!packages/contracts/generated",
      "!packages/server-core/src/persistence/schema.ts",
      "!packages/server-core/src/persistence/relations.ts",
      "!packages/server-core/drizzle/meta",
      "!**/*.map",
      "!.secrets",
      "!.env",
      "!.env.*",
      ".env.example"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noImportCycles": "error"
      },
      "style": {
        "useImportType": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "quoteProperties": "asNeeded",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false
    }
  },
  "overrides": [
    {
      "includes": [
        "packages/server-core/src/domain/**/*.ts",
        "packages/server-core/src/*/domain/**/*.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "next/**",
                      "livekit-*",
                      "@aws-sdk/**",
                      "drizzle-orm/**",
                      "nodemailer/**"
                    ],
                    "message": "Domain code cannot import framework, provider, or persistence adapters."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/web/**/*.ts", "apps/web/**/*.tsx", "apps/control-worker/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@transhooter/web/**", "@transhooter/control-worker/**"],
                    "message": "Applications may share packages but cannot import each other."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}

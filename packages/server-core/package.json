{
  "name": "@transhooter/server-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./consultations": {
      "types": "./dist/consultations/index.d.ts",
      "import": "./dist/consultations/index.js"
    },
    "./rooms": {
      "types": "./dist/rooms/index.d.ts",
      "import": "./dist/rooms/index.js"
    },
    "./languages": {
      "types": "./dist/languages/index.d.ts",
      "import": "./dist/languages/index.js"
    },
    "./archives": {
      "types": "./dist/archives/index.d.ts",
      "import": "./dist/archives/index.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "import": "./dist/ports/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "import": "./dist/persistence/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.build.json && tsc -p tsconfig.json --noEmit",
    "test": "bun test tests",
    "build": "tsc -p tsconfig.build.json",
    "prisma:generate": "prisma generate",
    "migration:generate": "prisma migrate dev --create-only",
    "migration:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@transhooter/contracts": "workspace:*",
    "@types/pg": "8.20.0",
    "pg": "8.16.3",
    "prisma": "7.6.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.5",
    "@types/node": "24.10.1",
    "typescript": "5.9.3"
  }
}

#!/bin/sh
set -eu
. "$(dirname -- "$0")/../deploy/scripts/compose-lib.sh"

profile=google-eu
if [ "${1:-}" = "--provider-profile" ]; then
  test "$#" -eq 2 || { echo "usage: ./scripts/dev-up [--provider-profile google-eu|google-speech-eu|deepgram-deepl-eu|fixture]" >&2; exit 2; }
  profile=$2
elif [ "$#" -ne 0 ]; then
  echo "usage: ./scripts/dev-up [--provider-profile google-eu|google-speech-eu|deepgram-deepl-eu|fixture]" >&2
  exit 2
fi

if [ "$profile" = fixture ] && [ -z "${COMPOSE_PROJECT_NAME:-}" ]; then
  PROJECT_NAME=transhooter-fixture
  export COMPOSE_PROJECT_NAME=$PROJECT_NAME
fi
# The fixture overlay and its browser harness use these canonical in-network
# hostnames. Do not let unrelated URLs inherited from a provider-profile shell
# silently redirect the fixture lifecycle.
if [ "$profile" = fixture ]; then
  export PUBLIC_BASE_URL=http://app.localhost:3000
  export PUBLIC_LIVEKIT_URL=ws://rtc.localhost:7880
  export S3_PUBLIC_ENDPOINT=http://localhost:9000
fi
export RTC_ADVERTISED_IP="${RTC_ADVERTISED_IP:-${RTC_BRIDGE_IP:-10.254.231.10}}"

mkdir -p "$ROOT/.secrets"

resolve_profile "$profile"
case "$profile" in
  google-eu|google-speech-eu)
    test -s "$ROOT/.secrets/google-adc.json" || { echo "Missing .secrets/google-adc.json" >&2; exit 1; }
    ;;
  deepgram-deepl-eu)
    test -s "$ROOT/.secrets/deepgram-api-key" || { echo "Missing .secrets/deepgram-api-key" >&2; exit 1; }
    test -s "$ROOT/.secrets/deepl-api-key" || { echo "Missing .secrets/deepl-api-key" >&2; exit 1; }
    ;;
esac
validate_profile_configuration "$(compose config --environment)"


export OTEL_SDK_DISABLED=false

announce_phase "Initializing runtime secrets"
compose run --rm --no-deps secrets-init

announce_phase "Validating ${profile} Compose configuration"
compose config --quiet
write_compose_state
announce_phase "Recorded recoverable Compose state"
announce_phase "Building current sources and waiting for semantic readiness"
compose up --build --wait --remove-orphans otel-collector web
printf 'Transhooter is ready with profile %s.\n' "$profile"

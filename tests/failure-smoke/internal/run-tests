#!/bin/sh
set -eu

if [ -n "${TRANSHOOTER_ROOT:-}" ] &&
  [ -d "$TRANSHOOTER_ROOT" ] &&
  [ -f "$TRANSHOOTER_ROOT/deploy/scripts/compose-lib.sh" ] &&
  [ -d "$TRANSHOOTER_ROOT/tests/failure-smoke" ]; then
  ROOT=$(CDPATH= cd -- "$TRANSHOOTER_ROOT" && pwd)
else
  ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)
fi
REPOSITORY_ROOT=$ROOT

CONTRACT_SCRIPT_DIRECTORY=${CONTRACT_SCRIPT_DIRECTORY:-"$ROOT/tests/e2e"}

validate_lightweight_contract_discovery() {
  for contract_script in "$CONTRACT_SCRIPT_DIRECTORY"/*contract*.test.sh; do
    [ -e "$contract_script" ] || continue
    case "${contract_script##*/}" in
      *-integration.test.sh) ;;
      *-contracts.test.sh)
        if [ ! -x "$contract_script" ]; then
          printf 'Lightweight contract script is not executable: %s\n' "$contract_script" >&2
          return 1
        fi
        ;;
      *)
        printf 'Contract script exists but is omitted from lightweight discovery: %s\n' \
          "$contract_script" >&2
        return 1
        ;;
    esac
  done
}

run_discovered_lightweight_contract_scripts() {
  validate_lightweight_contract_discovery
  for contract_script in "$CONTRACT_SCRIPT_DIRECTORY"/*-contracts.test.sh; do
    [ -e "$contract_script" ] || continue
    "$contract_script"
  done
}

run_lightweight_contract_suites() {
  validate_lightweight_contract_discovery
  bun test \
    "$ROOT/tests/e2e/harness-contracts.test.mjs" \
    "$ROOT/tests/failure-smoke/harness-contracts.test.mjs"
  "$ROOT/tests/failure-smoke/wrapper-contracts.test.sh"
  run_discovered_lightweight_contract_scripts
}

if [ "$#" -eq 1 ] && [ "$1" = "--contracts-only" ]; then
  run_lightweight_contract_suites
  exit 0
fi
if [ "$#" -eq 1 ] && [ "$1" = "--contract-discovery-only" ]; then
  validate_lightweight_contract_discovery
  exit 0
fi
if [ "$#" -eq 1 ] && [ "$1" = "--contract-scripts-only" ]; then
  run_discovered_lightweight_contract_scripts
  exit 0
fi

run_lightweight_contract_suites

. "$REPOSITORY_ROOT/deploy/scripts/compose-lib.sh"
ROOT=$REPOSITORY_ROOT
STATE_FILE="$ROOT/.secrets/compose-state"
BASE_FILE="$ROOT/deploy/compose/compose.yml"

LOCK_FILE=${COMPOSE_HARNESS_LOCK_FILE:-"${TMPDIR:-/tmp}/transhooter-compose-harness.lock"}
LOCK_WAIT_SECONDS=${COMPOSE_HARNESS_LOCK_WAIT_SECONDS:-300}
BUILD_DEADLINE_SECONDS=${COMPOSE_BUILD_DEADLINE_SECONDS:-1800}
START_DEADLINE_SECONDS=${COMPOSE_START_DEADLINE_SECONDS:-900}
TEST_DEADLINE_SECONDS=${COMPOSE_TEST_DEADLINE_SECONDS:-1800}
CLEANUP_DEADLINE_SECONDS=${COMPOSE_CLEANUP_DEADLINE_SECONDS:-300}

RUN_DIRECTORY=$(mktemp -d "${TMPDIR:-/tmp}/transhooter-test.XXXXXXXX") || {
  printf 'Unable to create an isolated test directory.\n' >&2
  exit 1
}
chmod 0700 "$RUN_DIRECTORY" || {
  rm -rf -- "$RUN_DIRECTORY"
  exit 1
}
COMPOSE_ENV_FILE="$RUN_DIRECTORY/compose.env"
if ! (umask 077 && : > "$COMPOSE_ENV_FILE"); then
  printf 'Unable to create an isolated Compose environment file.\n' >&2
  rm -rf -- "$RUN_DIRECTORY"
  exit 1
fi
RUN_ID=$(printf '%s' "${RUN_DIRECTORY##*.}" | tr '[:upper:]' '[:lower:]')
PROJECT_NAME="transhooter-test-$RUN_ID"
export COMPOSE_PROJECT_NAME="$PROJECT_NAME"
export APP_IMAGE_NAMESPACE="${APP_IMAGE_NAMESPACE:-transhooter-harness}"

OVERLAY_FILE="$ROOT/deploy/compose/compose.test.yml"
export APP_ENV=test
export PROVIDER_PROFILE=fixture
export BOOTSTRAP_ADMIN_EMAIL="${BOOTSTRAP_ADMIN_EMAIL:-admin@example.test}"
export BOOTSTRAP_ADMIN_NAME="${BOOTSTRAP_ADMIN_NAME:-Test Administrator}"
export RTC_SUBNET="${TEST_RTC_SUBNET:-10.254.232.0/24}"
export RTC_NODE_IP="${TEST_RTC_NODE_IP:-10.254.232.250}"

require_deadline() {
  name=$1
  value=$2
  case "$value" in
    "" | *[!0-9]* | 0)
      printf '%s must be a positive integer, got %s.\n' "$name" "$value" >&2
      rm -rf -- "$RUN_DIRECTORY"
      exit 2
      ;;
  esac
}

require_deadline COMPOSE_HARNESS_LOCK_WAIT_SECONDS "$LOCK_WAIT_SECONDS"
require_deadline COMPOSE_BUILD_DEADLINE_SECONDS "$BUILD_DEADLINE_SECONDS"
require_deadline COMPOSE_START_DEADLINE_SECONDS "$START_DEADLINE_SECONDS"
require_deadline COMPOSE_TEST_DEADLINE_SECONDS "$TEST_DEADLINE_SECONDS"
require_deadline COMPOSE_CLEANUP_DEADLINE_SECONDS "$CLEANUP_DEADLINE_SECONDS"
select_compose_command_bounded() {
  detection_deadline=15
  announce_phase "Selecting Docker Compose plugin (deadline: ${detection_deadline}s)"
  if ! timeout --signal=TERM --kill-after=5s "${detection_deadline}s" docker compose version >/dev/null 2>&1; then
    printf 'Phase "Selecting Docker Compose plugin" failed or exceeded its deadline.\n' >&2
    rm -rf -- "$RUN_DIRECTORY"
    exit 127
  fi
}

select_compose_command_bounded


compose_with_deadline() {
  phase=$1
  deadline=$2
  shift 2
  announce_phase "$phase (deadline: ${deadline}s)"

  set -- --env-file "$COMPOSE_ENV_FILE" -p "$PROJECT_NAME" -f "$BASE_FILE" -f "$OVERLAY_FILE" "$@"

  set -- docker compose "$@"

  if timeout --signal=TERM --kill-after=15s "${deadline}s" "$@"; then
    return 0
  else
    phase_status=$?
  fi
  if [ "$phase_status" -eq 124 ] || [ "$phase_status" -eq 137 ]; then
    printf 'Phase "%s" exceeded its absolute %ss deadline; its process tree was terminated.\n' "$phase" "$deadline" >&2
  else
    printf 'Phase "%s" failed with status %s.\n' "$phase" "$phase_status" >&2
  fi
  return "$phase_status"
}

exec 9>"$LOCK_FILE"
announce_phase "Waiting for the compose harness lock (deadline: ${LOCK_WAIT_SECONDS}s)"
if ! flock -w "$LOCK_WAIT_SECONDS" 9; then
  printf 'Phase "Waiting for the compose harness lock" exceeded its absolute %ss deadline.\n' "$LOCK_WAIT_SECONDS" >&2
  rm -rf -- "$RUN_DIRECTORY"
  exit 1
fi

cleanup() {
  status=$?
  trap - 0 HUP INT TERM
  if [ "${HERMETIC_REMOVE_LOCAL_IMAGES:-false}" = true ]; then
    cleanup_image_arguments="--rmi local"
  else
    cleanup_image_arguments=
  fi
  # shellcheck disable=SC2086
  compose_with_deadline "Cleaning hermetic test stack" "$CLEANUP_DEADLINE_SECONDS" down $cleanup_image_arguments --volumes --remove-orphans || {
    cleanup_status=$?
    if [ "$status" -eq 0 ]; then
      status=$cleanup_status
    fi
  }
  rm -rf -- "$RUN_DIRECTORY"
  flock -u 9
  exit "$status"
}

trap cleanup 0
trap 'exit 130' HUP INT TERM

compose_with_deadline "Removing stale hermetic containers and volumes" "$CLEANUP_DEADLINE_SECONDS" down --volumes --remove-orphans
compose_with_deadline "Initializing isolated hermetic runtime secrets" "$START_DEADLINE_SECONDS" run --rm --no-deps secrets-init
compose_with_deadline "Building application and harness images from the current source tree" "$BUILD_DEADLINE_SECONDS" build minio egress-ready translation-worker web e2e failure-smoke test
compose_with_deadline "Starting hermetic test dependencies" "$START_DEADLINE_SECONDS" up --wait --no-build test-dependencies-ready
compose_with_deadline "Running hermetic type, boundary, and test gates" "$TEST_DEADLINE_SECONDS" run --rm --no-deps test

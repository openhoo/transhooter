#!/bin/sh
set -eu

if [ -n "${TRANSHOOTER_ROOT:-}" ] &&
  [ -d "$TRANSHOOTER_ROOT" ] &&
  [ -f "$TRANSHOOTER_ROOT/deploy/scripts/compose-lib.sh" ] &&
  [ -d "$TRANSHOOTER_ROOT/tests/failure-smoke" ]; then
  ROOT=$(CDPATH= cd -- "$TRANSHOOTER_ROOT" && pwd)
else
  ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)
fi
. "$ROOT/deploy/scripts/compose-lib.sh"

BUILD_ONLY=false
NO_BUILD=false
HOST_PROOF_FILE=
HOST_METRICS_FILE=
HOST_SCENARIO_LOG_FILE=
while [ "$#" -gt 0 ]; do
  case "$1" in
    --build-only)
      BUILD_ONLY=true
      shift
      ;;
    --no-build)
      NO_BUILD=true
      shift
      ;;
    --proof-file | --metrics-file | --scenario-log-file)
      option=$1
      [ "$#" -ge 2 ] || {
        printf '%s requires a path.\n' "$option" >&2
        exit 2
      }
      case "$option" in
        --proof-file) HOST_PROOF_FILE=$2 ;;
        --metrics-file) HOST_METRICS_FILE=$2 ;;
        --scenario-log-file) HOST_SCENARIO_LOG_FILE=$2 ;;
      esac
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *) break ;;
  esac
done
if $BUILD_ONLY && $NO_BUILD; then
  printf '%s\n' '--build-only and --no-build cannot be combined.' >&2
  exit 2
fi
case "${1:-}" in
  "" | -*) ;;
  *)
    printf 'Unexpected wrapper positional argument: %s\n' "$1" >&2
    exit 2
    ;;
esac

PROJECT_NAME="transhooter-failure-$$-$(date +%s%N)"
FAILURE_SMOKE_OWNED_PROJECT_NAME=$PROJECT_NAME
export COMPOSE_PROJECT_NAME="$PROJECT_NAME"
export APP_IMAGE_NAMESPACE="${APP_IMAGE_NAMESPACE:-transhooter-harness}"
if [ -z "$HOST_SCENARIO_LOG_FILE" ]; then
  if [ -n "$HOST_PROOF_FILE" ]; then
    case "$HOST_PROOF_FILE" in
      *.proof.json) HOST_SCENARIO_LOG_FILE="${HOST_PROOF_FILE%.proof.json}.scenario.log" ;;
      *) HOST_SCENARIO_LOG_FILE="$HOST_PROOF_FILE.scenario.log" ;;
    esac
  elif [ -n "$HOST_METRICS_FILE" ]; then
    case "$HOST_METRICS_FILE" in
      *.metrics.jsonl) HOST_SCENARIO_LOG_FILE="${HOST_METRICS_FILE%.metrics.jsonl}.scenario.log" ;;
      *) HOST_SCENARIO_LOG_FILE="$HOST_METRICS_FILE.scenario.log" ;;
    esac
  else
    HOST_SCENARIO_LOG_FILE="${FAILURE_SMOKE_OUTPUT_DIR:-$ROOT/artifacts/failure-smoke}/$PROJECT_NAME.scenario.log"
  fi
fi
OVERLAY_FILE="$ROOT/deploy/compose/compose.test.yml"
export APP_ENV=test
export PROVIDER_PROFILE=fixture
export BOOTSTRAP_ADMIN_EMAIL="${BOOTSTRAP_ADMIN_EMAIL:-admin@example.test}"
export BOOTSTRAP_ADMIN_NAME="${BOOTSTRAP_ADMIN_NAME:-Test Administrator}"
export RTC_SUBNET="${TEST_RTC_SUBNET:-10.254.232.0/24}"
export RTC_NODE_IP="${TEST_RTC_NODE_IP:-10.254.232.250}"
printf 'Stack proof classification: clean harness-owned stack (project=%s, label=com.docker.compose.project=%s).\n' \
  "$PROJECT_NAME" "$PROJECT_NAME" >&2

deadline_supplied=false
for argument do
  if [ "$argument" = "--deadline-epoch-ms" ]; then
    deadline_supplied=true
  fi
done

LOCK_FILE=${COMPOSE_HARNESS_LOCK_FILE:-"${TMPDIR:-/tmp}/transhooter-compose-harness.lock"}
LOCK_WAIT_SECONDS=${COMPOSE_HARNESS_LOCK_WAIT_SECONDS:-300}
DEFAULT_PHASE_TIMEOUT_SECONDS=${COMPOSE_PHASE_TIMEOUT_SECONDS:-900}
COMPOSE_DETECTION_TIMEOUT_SECONDS=${COMPOSE_DETECTION_TIMEOUT_SECONDS:-15}
COMPOSE_SETUP_TIMEOUT_SECONDS=${COMPOSE_SETUP_TIMEOUT_SECONDS:-$DEFAULT_PHASE_TIMEOUT_SECONDS}
COMPOSE_BUILD_TIMEOUT_SECONDS=${COMPOSE_BUILD_TIMEOUT_SECONDS:-$DEFAULT_PHASE_TIMEOUT_SECONDS}
COMPOSE_SCENARIO_TIMEOUT_SECONDS=${COMPOSE_SCENARIO_TIMEOUT_SECONDS:-${FAILURE_SMOKE_DEADLINE_SECONDS:-3600}}
COMPOSE_DIAGNOSTIC_TIMEOUT_SECONDS=${COMPOSE_DIAGNOSTIC_TIMEOUT_SECONDS:-120}
COMPOSE_OWNERSHIP_TIMEOUT_SECONDS=${COMPOSE_OWNERSHIP_TIMEOUT_SECONDS:-60}
COMPOSE_CLEANUP_TIMEOUT_SECONDS=${COMPOSE_CLEANUP_TIMEOUT_SECONDS:-300}
ACTIVE_PID=
LOCK_HELD=false

RUN_DIRECTORY=$(mktemp -d "${TMPDIR:-/tmp}/transhooter-failure-smoke.XXXXXXXX")
chmod 0700 "$RUN_DIRECTORY"
RESOURCE_PROOF_FILE="$RUN_DIRECTORY/compose-resources"
PROOF_DIRECTORY="$RUN_DIRECTORY/proof"
mkdir "$PROOF_DIRECTORY"
chmod 0777 "$PROOF_DIRECTORY"
METRICS_FILE="$RUN_DIRECTORY/wrapper-metrics.jsonl"
PROOF_FILE="$PROOF_DIRECTORY/proof.json"
: > "$METRICS_FILE"
SCENARIO_STARTED=false
SCENARIO_LOG="$RUN_DIRECTORY/scenario.log"

require_positive_seconds() {
  name=$1
  value=$2
  case "$value" in
    "" | *[!0-9]* | 0)
      printf '%s must be a positive integer, got %s.\n' "$name" "$value" >&2
      exit 2
      ;;
  esac
}

require_positive_seconds COMPOSE_HARNESS_LOCK_WAIT_SECONDS "$LOCK_WAIT_SECONDS"
require_positive_seconds COMPOSE_DETECTION_TIMEOUT_SECONDS "$COMPOSE_DETECTION_TIMEOUT_SECONDS"
require_positive_seconds COMPOSE_SETUP_TIMEOUT_SECONDS "$COMPOSE_SETUP_TIMEOUT_SECONDS"
require_positive_seconds COMPOSE_BUILD_TIMEOUT_SECONDS "$COMPOSE_BUILD_TIMEOUT_SECONDS"
require_positive_seconds COMPOSE_SCENARIO_TIMEOUT_SECONDS "$COMPOSE_SCENARIO_TIMEOUT_SECONDS"
require_positive_seconds COMPOSE_DIAGNOSTIC_TIMEOUT_SECONDS "$COMPOSE_DIAGNOSTIC_TIMEOUT_SECONDS"
require_positive_seconds COMPOSE_OWNERSHIP_TIMEOUT_SECONDS "$COMPOSE_OWNERSHIP_TIMEOUT_SECONDS"
require_positive_seconds COMPOSE_CLEANUP_TIMEOUT_SECONDS "$COMPOSE_CLEANUP_TIMEOUT_SECONDS"
if ! $BUILD_ONLY && ! $deadline_supplied; then
  deadline_epoch_ms=$((($(date +%s) + ${FAILURE_SMOKE_DEADLINE_SECONDS:-3600}) * 1000))
  set -- "$@" --deadline-epoch-ms "$deadline_epoch_ms"
fi

record_metric() {
  metric_name=$1
  metric_started_ns=$2
  metric_status=$3
  metric_finished_ns=$(date +%s%N)
  metric_duration_ms=$(((metric_finished_ns - metric_started_ns) / 1000000))
  printf '{"name":"%s","durationMs":%s,"status":"%s"}\n' \
    "$metric_name" "$metric_duration_ms" "$metric_status" >> "$METRICS_FILE"
}

terminate_active() {
  signal_status=$1
  trap - HUP INT TERM
  if [ -n "$ACTIVE_PID" ]; then
    kill -TERM -- "-$ACTIVE_PID" 2>/dev/null || true
    wait "$ACTIVE_PID" 2>/dev/null || true
    ACTIVE_PID=
  fi
  exit "$signal_status"
}

run_bounded() {
  phase=$1
  phase_timeout=$2
  shift 2
  phase_started_ns=$(date +%s%N)
  announce_phase "$phase (deadline: ${phase_timeout}s)"
  setsid timeout --signal=TERM --kill-after=10s "${phase_timeout}s" "$@" &
  ACTIVE_PID=$!
  if wait "$ACTIVE_PID"; then
    result=0
  else
    result=$?
  fi
  ACTIVE_PID=
  if [ "$result" -eq 0 ]; then
    metric_status=success
  else
    metric_status=failure
  fi
  record_metric "$phase" "$phase_started_ns" "$metric_status"
  case "$result" in
    124 | 137)
      printf 'Phase "%s" exceeded its absolute %ss deadline; its process group was terminated.\n' \
        "$phase" "$phase_timeout" >&2
      ;;
    0) ;;
    *)
      printf 'Phase "%s" failed with status %s.\n' "$phase" "$result" >&2
      ;;
  esac
  return "$result"
}

select_compose_command_bounded() {
  if ! run_bounded "Detecting Docker Compose plugin" "$COMPOSE_DETECTION_TIMEOUT_SECONDS" \
    docker compose version >/dev/null 2>&1; then
    printf 'Docker Compose plugin is required.\n' >&2
    return 127
  fi
}

case "$(docker --version 2>/dev/null)" in
  podman*) CONTAINER_ENGINE_KIND=podman ;;
  *) CONTAINER_ENGINE_KIND=docker ;;
esac

compose_bounded() {
  phase=$1
  phase_timeout=$2
  shift 2
  set -- -p "$PROJECT_NAME" -f "$BASE_FILE" -f "$OVERLAY_FILE" "$@"
  if [ -f "$ROOT/.env" ]; then
    set -- --env-file "$ROOT/.env" "$@"
  fi
  run_bounded "$phase" "$phase_timeout" docker compose "$@"
}

stale_failure_smoke_projects() {
  if [ "$CONTAINER_ENGINE_KIND" = podman ]; then
    {
      docker ps --all --filter "label=com.docker.compose.project" --format '{{.ID}}' |
        while IFS= read -r id; do
          [ -n "$id" ] &&
            docker inspect --format '{{ index .Config.Labels "com.docker.compose.project" }}' "$id"
        done
      docker network ls --filter "label=com.docker.compose.project" --format '{{.ID}}' |
        while IFS= read -r id; do
          [ -n "$id" ] &&
            docker network inspect --format '{{ index .Labels "com.docker.compose.project" }}' "$id"
        done
      docker volume ls --filter "label=com.docker.compose.project" --format '{{.Name}}' |
        while IFS= read -r name; do
          [ -n "$name" ] &&
            docker volume inspect --format '{{ index .Labels "com.docker.compose.project" }}' "$name"
        done
    }
  else
    {
      docker ps --all --filter "label=com.docker.compose.project" \
        --format '{{.Label "com.docker.compose.project"}}'
      docker network ls --filter "label=com.docker.compose.project" \
        --format '{{.Label "com.docker.compose.project"}}'
      docker volume ls --filter "label=com.docker.compose.project" \
        --format '{{.Label "com.docker.compose.project"}}'
    }
  fi |
    sort -u |
    while IFS= read -r candidate; do
      [ -n "$candidate" ] || continue
      failure_smoke_project_is_stale "$candidate" "$PROJECT_NAME" || continue
      printf '%s\n' "$candidate"
    done
}

cleanup_stale_failure_smoke_projects() {
  stale_projects=$(stale_failure_smoke_projects) || return $?
  [ -n "$stale_projects" ] || return 0
  printf '%s\n' "$stale_projects" | while IFS= read -r stale_project; do
    [ -n "$stale_project" ] || continue
    run_bounded "Cleaning stale failure-smoke stack $stale_project" \
      "$COMPOSE_CLEANUP_TIMEOUT_SECONDS" \
      docker compose -p "$stale_project" -f "$BASE_FILE" -f "$OVERLAY_FILE" \
        down --volumes --remove-orphans
  done
}

verify_failure_smoke_stack_ownership() {
  if ! failure_smoke_project_is_owned "$PROJECT_NAME" "$FAILURE_SMOKE_OWNED_PROJECT_NAME"; then
    printf 'Refusing cleanup: project %s is not the harness-owned failure-smoke stack.\n' \
      "$PROJECT_NAME" >&2
    return 1
  fi

  : > "$RESOURCE_PROOF_FILE"
  run_bounded "Classifying owned failure-smoke containers" "$COMPOSE_OWNERSHIP_TIMEOUT_SECONDS" \
    docker ps --all --filter "label=com.docker.compose.project=$PROJECT_NAME" \
      --format "container|{{.ID}}|$PROJECT_NAME" >> "$RESOURCE_PROOF_FILE" ||
    return $?
  run_bounded "Classifying owned failure-smoke networks" "$COMPOSE_OWNERSHIP_TIMEOUT_SECONDS" \
    docker network ls --filter "label=com.docker.compose.project=$PROJECT_NAME" \
      --format "network|{{.ID}}|$PROJECT_NAME" >> "$RESOURCE_PROOF_FILE" ||
    return $?
  run_bounded "Classifying owned failure-smoke volumes" "$COMPOSE_OWNERSHIP_TIMEOUT_SECONDS" \
    docker volume ls --filter "label=com.docker.compose.project=$PROJECT_NAME" \
      --format "volume|{{.Name}}|$PROJECT_NAME" >> "$RESOURCE_PROOF_FILE" ||
    return $?

  while IFS='|' read -r resource_kind resource_id resource_project_label; do
    [ -n "$resource_kind$resource_id$resource_project_label" ] || continue
    case "$resource_kind:$resource_id" in
      container:?* | network:?* | volume:?*) ;;
      *)
        printf 'Refusing cleanup: ambiguous Compose resource record %s/%s.\n' \
          "$resource_kind" "$resource_id" >&2
        return 1
        ;;
    esac
    if ! failure_smoke_resource_is_owned \
      "$PROJECT_NAME" "$FAILURE_SMOKE_OWNED_PROJECT_NAME" "$resource_project_label"; then
      printf 'Refusing cleanup: %s %s has external or ambiguous project label %s.\n' \
        "$resource_kind" "$resource_id" "${resource_project_label:-<missing>}" >&2
      return 1
    fi
  done < "$RESOURCE_PROOF_FILE"
}

copy_artifact() {
  source_file=$1
  destination_file=$2
  [ -n "$destination_file" ] || return 0
  [ -f "$source_file" ] || return 0
  destination_directory=$(dirname -- "$destination_file")
  destination_name=$(basename -- "$destination_file")
  mkdir -p -- "$destination_directory" || return $?
  temporary_file=$(mktemp "$destination_directory/.${destination_name}.XXXXXXXX") || return $?
  if cp -- "$source_file" "$temporary_file" &&
    chmod 0644 "$temporary_file" &&
    mv -f -- "$temporary_file" "$destination_file"; then
    return 0
  else
    copy_status=$?
  fi
  rm -f -- "$temporary_file"
  return "$copy_status"
}

early_cleanup() {
  status=$?
  trap - 0 HUP INT TERM
  copy_artifact "$METRICS_FILE" "$HOST_METRICS_FILE" || true
  rm -rf -- "$RUN_DIRECTORY"
  exit "$status"
}

trap early_cleanup 0
trap 'terminate_active 129' HUP
trap 'terminate_active 130' INT
trap 'terminate_active 143' TERM

select_compose_command_bounded
exec 9>"$LOCK_FILE"
lock_started_ns=$(date +%s%N)
announce_phase "Waiting for the compose harness lock (deadline: ${LOCK_WAIT_SECONDS}s)"
if flock -w "$LOCK_WAIT_SECONDS" 9; then
  LOCK_HELD=true
  record_metric "Waiting for the compose harness lock" "$lock_started_ns" success
else
  record_metric "Waiting for the compose harness lock" "$lock_started_ns" failure
  printf 'Phase "Waiting for the compose harness lock" exceeded its absolute %ss deadline.\n' \
    "$LOCK_WAIT_SECONDS" >&2
  copy_artifact "$METRICS_FILE" "$HOST_METRICS_FILE"
  rm -rf -- "$RUN_DIRECTORY"
  exit 1
fi
trap - 0

cleanup_stale_failure_smoke_projects

capture_database_diagnostics() {
  consultation_sql="SELECT state, generation, room_name IS NOT NULL AS room_name_set, room_sid IS NOT NULL AS room_sid_set, dispatch_id IS NOT NULL AS dispatch_id_set, composite_egress_id IS NOT NULL AS composite_egress_id_set FROM consultations ORDER BY created_at DESC LIMIT 3"
  external_effect_sql="SELECT generation, effect_kind, state, attempts, result ? 'error' AS has_error, max(result->>'error') AS latest_error, bool_or(lease_owner IS NOT NULL) AS leased, max(lease_expires_at) AS latest_lease_expiry, count(*) FROM external_effects GROUP BY generation, effect_kind, state, attempts, result ? 'error' ORDER BY generation, effect_kind, state, attempts, has_error"
  archive_sql="SELECT a.state, a.final_inventory_hash IS NOT NULL AS inventory_hashed, count(DISTINCT o.id) AS objects, count(DISTINCT m.id) FILTER (WHERE m.state IN ('open','completing')) AS pending_multipart FROM archives a LEFT JOIN archive_objects o ON o.archive_id=a.id LEFT JOIN multipart_uploads m ON m.archive_id=a.id GROUP BY a.id, a.state, a.final_inventory_hash ORDER BY a.created_at DESC LIMIT 3"

  outbox_sql="SELECT id, topic, aggregate_id, generation, payload->>'kind' AS effect_kind, payload->>'subjectId' AS subject_id, payload->>'resourceGeneration' AS resource_generation, available_at, lease_owner, lease_expires_at, attempts, payload->>'lastDispatchError' AS last_dispatch_error FROM outbox WHERE delivered_at IS NULL ORDER BY available_at, id"
  compose_bounded "Capturing database diagnostics" "$COMPOSE_DIAGNOSTIC_TIMEOUT_SECONDS" \
    run --rm --no-deps --workdir /workspace/tests/failure-smoke \
      -e "FAILURE_DIAGNOSTIC_CONSULTATION_SQL=$consultation_sql" \
      -e "FAILURE_DIAGNOSTIC_EXTERNAL_EFFECT_SQL=$external_effect_sql" \
      -e "FAILURE_DIAGNOSTIC_ARCHIVE_SQL=$archive_sql" \
      -e "FAILURE_DIAGNOSTIC_OUTBOX_SQL=$outbox_sql" \
      failure-smoke bun --eval '
      import postgres from "postgres";
      const diagnostics = [
        ["Capturing consultation diagnostics", process.env.FAILURE_DIAGNOSTIC_CONSULTATION_SQL],
        ["Capturing external-effect diagnostics", process.env.FAILURE_DIAGNOSTIC_EXTERNAL_EFFECT_SQL],
        ["Capturing archive recovery diagnostics", process.env.FAILURE_DIAGNOSTIC_ARCHIVE_SQL],
        ["Capturing outbox diagnostics", process.env.FAILURE_DIAGNOSTIC_OUTBOX_SQL],
      ];
      const connectionString = (await Bun.file(process.env.DATABASE_URL_FILE).text()).trim();
      const database = postgres(connectionString, {
        max: 1,
        prepare: false,
        connect_timeout: 10,
      });
      let failed = false;
      try {
        for (const [label, statement] of diagnostics) {
          console.log(`=== ${label} ===`);
          try {
            const rows = await database.unsafe(statement);
            for (const row of rows) console.log(JSON.stringify(row));
          } catch (error) {
            failed = true;
            console.error(`${label} failed:`, error);
          }
        }
      } finally {
        await database.end({ timeout: 1 });
      }
      if (failed) process.exitCode = 1;
    '
}

cleanup() {
  status=$?
  trap - 0 HUP INT TERM
  retain_run_directory=false
  if [ "$status" -ne 0 ] && ! $BUILD_ONLY; then
    compose_bounded "Capturing failure-smoke service status" "$COMPOSE_DIAGNOSTIC_TIMEOUT_SECONDS" ps || true
    compose_bounded "Capturing failure-smoke logs" "$COMPOSE_DIAGNOSTIC_TIMEOUT_SECONDS" \
      logs --no-color --tail=80 web translation-worker spool-drainer control-worker-1 control-worker-2 capability-publisher language-refresh postgres-role-bootstrap postgres-capability-bootstrap migrate livekit egress minio || true
    capture_database_diagnostics || true
  fi
  if verify_failure_smoke_stack_ownership; then
    if ! compose_bounded "Cleaning owned failure-smoke stack $PROJECT_NAME" \
      "$COMPOSE_CLEANUP_TIMEOUT_SECONDS" down --volumes --remove-orphans; then
      [ "$status" -ne 0 ] || status=1
    fi
  else
    [ "$status" -ne 0 ] || status=1
    printf 'Owned failure-smoke stack classification failed; no cleanup command was run.\n' >&2
  fi
  if [ "$status" -ne 0 ] && $SCENARIO_STARTED && [ -f "$SCENARIO_LOG" ]; then
    if copy_artifact "$SCENARIO_LOG" "$HOST_SCENARIO_LOG_FILE"; then
      printf 'Complete failure-smoke scenario log: %s\n' "$HOST_SCENARIO_LOG_FILE" >&2
    else
      retain_run_directory=true
      printf 'Failed to preserve complete failure-smoke scenario log at %s; source retained at %s.\n' \
        "$HOST_SCENARIO_LOG_FILE" "$SCENARIO_LOG" >&2
    fi
    tail -n 200 "$SCENARIO_LOG" >&2
  fi
  copy_artifact "$PROOF_FILE" "$HOST_PROOF_FILE" || {
    [ "$status" -ne 0 ] || status=1
  }
  copy_artifact "$METRICS_FILE" "$HOST_METRICS_FILE" || {
    [ "$status" -ne 0 ] || status=1
  }
  $retain_run_directory || rm -rf -- "$RUN_DIRECTORY"
  if $LOCK_HELD; then
    flock -u 9
  fi
  exit "$status"
}

trap cleanup 0
trap 'terminate_active 129' HUP
trap 'terminate_active 130' INT
trap 'terminate_active 143' TERM

if $BUILD_ONLY; then
  compose_bounded "Building failure-smoke application and harness images" "$COMPOSE_BUILD_TIMEOUT_SECONDS" \
    build minio egress-ready translation-worker spool-drainer web failure-smoke
  exit 0
fi

compose_bounded "Initializing failure-smoke runtime secrets" "$COMPOSE_SETUP_TIMEOUT_SECONDS" \
  run --rm --no-deps secrets-init
if ! $NO_BUILD; then
  compose_bounded "Building failure-smoke application and harness images" "$COMPOSE_BUILD_TIMEOUT_SECONDS" \
    build minio egress-ready translation-worker spool-drainer web failure-smoke
fi
SCENARIO_STARTED=true
if compose_bounded "Running failure injection scenarios" "$COMPOSE_SCENARIO_TIMEOUT_SECONDS" \
  run --rm -v "$PROOF_DIRECTORY:/proof" -e FAILURE_SMOKE_PROOF_FILE=/proof/proof.json \
    failure-smoke bun ../failure-smoke/failure-smoke.mjs "$@" >"$SCENARIO_LOG" 2>&1; then
  cat "$SCENARIO_LOG"
else
  exit $?
fi
